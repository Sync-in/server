{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": {
      "type": "swc",
      "options": {
        "ignore": ["**/*spec.ts"]
      }
    },
    "typeCheck": true,
    "deleteOutDir": true,
    "watchAssets": true,
    "assets": [
      {
        "include": "./applications/files/assets"
      },
      {
        "include": "./common/fonts"
      }
    ]
  }
}
